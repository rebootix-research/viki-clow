# VikiClow .env example
#
# Quick start:
# 1) Copy this file to `.env` (for local runs from this repo), OR to `~/.vikiclow/.env` (for launchd/systemd daemons).
# 2) Fill only the values you use.
# 3) Keep real secrets out of git.
#
# Env-source precedence for environment variables (highest -> lowest):
# process env, ./.env, ~/.vikiclow/.env, then vikiclow.json `env` block.
# Existing non-empty process env vars are not overridden by dotenv/config env loading.
# Note: direct config keys (for example `gateway.auth.token` or channel tokens in vikiclow.json)
# are resolved separately from env loading and often take precedence over env fallbacks.

# -----------------------------------------------------------------------------
# Gateway auth + paths
# -----------------------------------------------------------------------------
# Recommended if the gateway binds beyond loopback.
VIKICLOW_GATEWAY_TOKEN=change-me-to-a-long-random-token
# Example generator: openssl rand -hex 32

# Optional alternative auth mode (use token OR password).
# VIKICLOW_GATEWAY_PASSWORD=change-me-to-a-strong-password

# Optional path overrides (defaults shown for reference).
# VIKICLOW_STATE_DIR=~/.vikiclow
# VIKICLOW_CONFIG_PATH=~/.vikiclow/vikiclow.json
# VIKICLOW_HOME=~

# Optional: import missing keys from your login shell profile.
# VIKICLOW_LOAD_SHELL_ENV=1
# VIKICLOW_SHELL_ENV_TIMEOUT_MS=15000

# -----------------------------------------------------------------------------
# Model provider API keys (set at least one)
# -----------------------------------------------------------------------------
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=...
# OPENROUTER_API_KEY=sk-or-...
# VIKICLOW_LIVE_OPENAI_KEY=sk-...
# VIKICLOW_LIVE_ANTHROPIC_KEY=sk-ant-...
# VIKICLOW_LIVE_GEMINI_KEY=...
# OPENAI_API_KEY_1=...
# ANTHROPIC_API_KEY_1=...
# GEMINI_API_KEY_1=...
# GOOGLE_API_KEY=...
# OPENAI_API_KEYS=sk-1,sk-2
# ANTHROPIC_API_KEYS=sk-ant-1,sk-ant-2
# GEMINI_API_KEYS=key-1,key-2

# Optional additional providers
# ZAI_API_KEY=...
# AI_GATEWAY_API_KEY=...
# MINIMAX_API_KEY=...
# SYNTHETIC_API_KEY=...

# -----------------------------------------------------------------------------
# Channels (only set what you enable)
# -----------------------------------------------------------------------------
# TELEGRAM_BOT_TOKEN=123456:ABCDEF...
# DISCORD_BOT_TOKEN=...
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_APP_TOKEN=xapp-...

# Optional channel env fallbacks
# MATTERMOST_BOT_TOKEN=...
# MATTERMOST_URL=https://chat.example.com
# ZALO_BOT_TOKEN=...
# VIKICLOW_TWITCH_ACCESS_TOKEN=oauth:...

# -----------------------------------------------------------------------------
# Tools + voice/media (optional)
# -----------------------------------------------------------------------------
# BRAVE_API_KEY=...
# PERPLEXITY_API_KEY=pplx-...
# FIRECRAWL_API_KEY=...

# ELEVENLABS_API_KEY=...
# XI_API_KEY=...  # alias for ElevenLabs
# DEEPGRAM_API_KEY=...

# -----------------------------------------------------------------------------
# Durable mission + memory backbones (optional, recommended for full runtime)
# -----------------------------------------------------------------------------
# VIKICLOW_TEMPORAL_ADDRESS=127.0.0.1:7233
# VIKICLOW_TEMPORAL_NAMESPACE=vikiclow
# VIKICLOW_TEMPORAL_QUEUE=vikiclow-missions
#
# VIKICLOW_LANGGRAPH_ENDPOINT=http://127.0.0.1:8123
# VIKICLOW_LANGGRAPH_HEALTHCHECK_PATH=/ok
#
# VIKICLOW_MEMORY_BACKEND=graphiti
# VIKICLOW_GRAPHITI_NEO4J_URI=neo4j://127.0.0.1:7687
# VIKICLOW_GRAPHITI_NEO4J_USER=neo4j
# VIKICLOW_GRAPHITI_NEO4J_PASSWORD=change-me
# VIKICLOW_GRAPHITI_NEO4J_DATABASE=neo4j
# VIKICLOW_GRAPHITI_LOCAL_STORE=~/.vikiclow/memory/graphiti/main
# VIKICLOW_GRAPHITI_TIMEOUT_MS=5000

# -----------------------------------------------------------------------------
# Durable runtime stack (optional for local proofs / self-hosted backends)
# -----------------------------------------------------------------------------
# Temporal mission runtime
# VIKICLOW_TEMPORAL_ADDRESS=127.0.0.1:7233
# VIKICLOW_TEMPORAL_NAMESPACE=vikiclow
#
# LangGraph orchestration endpoint
# Local Docker proof uses `http://127.0.0.1:12024`.
# VIKICLOW_LANGGRAPH_ENDPOINT=http://127.0.0.1:2024
# VIKICLOW_LANGGRAPH_HEALTHCHECK_PATH=/ok
#
# Graphiti / Neo4j memory backbone
# VIKICLOW_MEMORY_BACKEND=graphiti
# VIKICLOW_GRAPHITI_NEO4J_URI=bolt://127.0.0.1:7687
# VIKICLOW_GRAPHITI_NEO4J_USER=neo4j
# VIKICLOW_GRAPHITI_NEO4J_PASSWORD=change-me
# VIKICLOW_GRAPHITI_NEO4J_DATABASE=neo4j
# VIKICLOW_GRAPHITI_LOCAL_STORE=~/.vikiclow/memory/graphiti/main
# VIKICLOW_GRAPHITI_TIMEOUT_MS=5000
