{
  "name": "@vikiclow/tlon",
  "version": "2026.3.9",
  "description": "VikiClow Tlon/Urbit channel plugin",
  "type": "module",
  "dependencies": {
    "@tloncorp/api": "github:tloncorp/api-beta#7eede1c1a756977b09f96aa14a92e2b06318ae87",
    "@tloncorp/tlon-skill": "0.2.2",
    "@urbit/aura": "^3.0.0",
    "zod": "^4.3.6"
  },
  "vikiclow": {
    "extensions": [
      "./index.ts"
    ],
    "channel": {
      "id": "tlon",
      "label": "Tlon",
      "selectionLabel": "Tlon (Urbit)",
      "docsPath": "/channels/tlon",
      "docsLabel": "tlon",
      "blurb": "decentralized messaging on Urbit; install the plugin to enable.",
      "order": 90,
      "quickstartAllowFrom": true
    },
    "install": {
      "npmSpec": "@vikiclow/tlon",
      "localPath": "extensions/tlon",
      "defaultChoice": "npm"
    },
    "releaseChecks": {
      "rootDependencyMirrorAllowlist": [
        "@tloncorp/api",
        "@tloncorp/tlon-skill",
        "@urbit/aura"
      ]
    }
  }
}
